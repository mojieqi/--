<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.CwPostImageMapper">

    <resultMap type="com.ruoyi.system.domain.CwPostImage" id="CwPostImageResult">
        <result property="imageId"      column="image_id"/>
        <result property="postId"       column="post_id"/>
        <result property="imageUrl"     column="image_url"/>
        <result property="thumbnailUrl" column="thumbnail_url"/>
        <result property="sort"         column="sort"/>
        <result property="createTime"   column="create_time"/>
    </resultMap>

    <select id="selectImagesByPostId" parameterType="Long" resultMap="CwPostImageResult">
        select image_id, post_id, image_url, thumbnail_url, sort, create_time
        from cw_post_image
        where post_id = #{postId}
        order by sort asc
    </select>

    <insert id="batchInsertImages" parameterType="java.util.List">
        insert into cw_post_image (post_id, image_url, thumbnail_url, sort, create_time)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.postId}, #{item.imageUrl}, #{item.thumbnailUrl}, #{item.sort}, sysdate())
        </foreach>
    </insert>

    <delete id="deleteImagesByPostId" parameterType="Long">
        delete from cw_post_image where post_id = #{postId}
    </delete>

</mapper>
